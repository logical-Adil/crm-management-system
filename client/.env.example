# =============================================================================
# Next.js client — copy to `.env.local` and adjust if needed.
# =============================================================================
# Keep in sync with the Nest app in `/server`:
#   - `PORT` (default 5000) → host in NEXT_PUBLIC_API_URL
#   - Global prefix `/api` + version `v1` → path must be `/api/v1`
#   - `CORS_ORIGINS` on the server must include the frontend origin (e.g. `https://itsadil.site`, no path)
#
# Server template: server/.env.example
# HTTP reference: server/POSTMAN_API.md
# =============================================================================

# This app's public URL (deployed under /client). Listed in server CORS_ORIGINS.
NEXT_PUBLIC_APP_URL=https://itsadil.site/client

# Next.js base path when app is served under a subpath.
NEXT_PUBLIC_BASE_PATH=/client

# Nest API base — no trailing slash (append paths like /auth/login).
NEXT_PUBLIC_API_URL=https://itsadil.site/api/v1
