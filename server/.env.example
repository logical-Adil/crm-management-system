# Application Config
NODE_ENV=local
PORT=5000
APP_NAME=API_BACKEND
CORS_ORIGINS=http://localhost:3000,http://localhost:5000
APP_PRIVATE_KEY_PATH=/secrets/app-private-key.pem

# Database configuration for docker
DATABASE_USER=postgres
DATABASE_PASSWORD=strongpassword
DATABASE_NAME=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Runtime (Nest + PrismaClient): pooled connection. For Supabase use Transaction pooler :6543 + ?pgbouncer=true
DATABASE_URL=postgres://postgres:strongpassword@localhost:5432/postgres

# Prisma CLI only (migrate, db push). For local Docker, match DATABASE_URL.
# Supabase: use Session pooler :5432 (user postgres.PROJECT_REF @ *.pooler.supabase.com) if direct db.*.supabase.co gives P1001 on IPv4.
DIRECT_URL=postgres://postgres:strongpassword@localhost:5432/postgres

# JWT Config (use a strong secret in production - min 32 chars)
JWT_SECRET=thisisasamplesecretchangemeinproduction
JWT_ACCESS_EXPIRATION_MINUTES=15
JWT_REFRESH_EXPIRATION_DAYS=30

# Seed: multiple demo organizations + admin users (see prisma/seed.ts). Same password for all seeded admins.
SEED_ADMIN_PASSWORD=ChangeMe@123!

# SMTP configuration options for the email service
# For testing, you can use a fake SMTP service like Ethereal: https://ethereal.email/create
SMTP_HOST=email-server
SMTP_PORT=587
SMTP_USERNAME=email-server-username
SMTP_PASSWORD=email-server-password
EMAIL_FROM=support@yourapp.com
